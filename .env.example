# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Lark / Feishu Integration ---
# LARK_WEBHOOK_URL: Incoming webhook URL from a Feishu/Lark bot.
# Create one at: Feishu Admin > Group Settings > Add Bot > Custom Bot > Webhook
# Required for the "Share to Lark Channel" button in the Advice Card Studio.
LARK_WEBHOOK_URL="https://open.larksuite.com/open-apis/bot/v2/hook/YOUR_WEBHOOK_TOKEN"

# LARK_APP_ID / LARK_APP_SECRET: Credentials for the larksuite MCP server in .mcp.json.
# Create an app at: https://open.larksuite.com/app
# Used by Claude Code's MCP tools (not the app backend).
LARK_APP_ID="cli_XXXXXXXXXXXXXXXX"
LARK_APP_SECRET="YOUR_LARK_APP_SECRET"

# --- getlark.ai Test Automation ---
# GETLARK_API_KEY: API key for getlark.ai workflow automation.
# Get one at: https://dashboard.getlark.ai/settings/api-keys
# Required for: npm run test:lark and npm run lark:setup
GETLARK_API_KEY="lrk_api_key_XXXXXXXXXXXXXXXX"
